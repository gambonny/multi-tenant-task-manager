{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "backend",
	"main": "src/index.ts",
	"compatibility_date": "2025-09-27",
	"observability": {
		"enabled": true
	},
	"compatibility_flags": ["nodejs_compat"],
	"version_metadata": {
		"binding": "CF_VERSION_METADATA"
	},
	"vars": {
		"ALLOWED_ORIGINS": "http://localhost:5173",
		"LOG_LEVEL": "debug",
		"LOG_FORMAT": "pretty"
	}
}
